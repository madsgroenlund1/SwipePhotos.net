  .rich-text--file-wrapper,
  .rich-text--audio-wrapper,
  .rich-text--video-wrapper {
    display: inline-block;
    width: 100%;
  }

  .rich-text--button--link {
    ${rze("button")};
  }

  .rich-text--file,
  [data-type="file"] {
    background-color: transparent;
    border-radius: 0.5rem;
    display: inline-block;
    width: auto !important;
    box-shadow: 0 0 0 1px ${Xy(.8,"paragraphText")};
    min-width: 40px;
    padding: 0.375rem 0.875rem;
    text-decoration: none !important;

    .preview {
      display: flex;
      align-items: center;
      gap: 0.5rem;

      svg {
        fill: ${Zy("paragraphText")};
      }

      .name {
        color: ${Zy("paragraphText")};
        text-decoration: underline;
      }

      .size {
        color: ${Xy(.25,"paragraphText")};
      }
    }
  }

  .rich-text--audio-wrapper {
    position: relative;
    margin-bottom: 0px !important;
  }

  .rich-text--audio {
    background-color: transparent;
    width: 100%;

    media-controller {
      margin-bottom: 0px !important;
      border-radius: 0.5rem;
      overflow: hidden;
      display: block;
      background-color: transparent;
      --media-control-background: rgb(0, 0, 0, 0.85);
      --media-control-hover-background: rgb(0, 0, 0, 0.8);
    }

    media-control-bar,
    media-time-range,
    media-controller {
      width: 100%;
    }

    media-time-display,
    media-play-button,
    media-playback-rate-button,
    media-mute-button {
      flex-shrink: 0;
    }

    // Responsive controls
    media-controller {
      media-mute-button,
      media-time-display {
        display: none;
      }
    }
    media-controller[breakpointmd],
    media-controller[breakpointlg],
    media-controller[breakpointxl] {
      media-mute-button,
      media-time-display {
        display: flex;
      }
    }

    .download-link {
      margin-top: 0.5rem;
    }

    .preview .name {
      color: ${Zy("paragraphText")};
      text-decoration: underline;
      margin-left: 0.3rem;
    }
  }

  .rich-text--video-wrapper {
    position: relative;
    margin-bottom: 0px !important;
  }

  .rich-text--video {
    background-color: transparent;
    width: 100%;

    .download-link {
      margin-top: 0.5rem;
    }

    .preview .name {
      color: ${Zy("paragraphText")};
      text-decoration: underline;
      margin-left: 0.3rem;
    }
  }

  // Cloudflare Player background color
  .bg-grey-dark {
    background-color: #06040e;
  }

  .text-sm {
    ${ow("body","sm")};
  }

  .text-lg {
    ${ow("body","lg")};
  }

  ${({theme:{layout:e},$isHeader:t,$freeAlignment:n})=>!n&&aze.css`
      text-align: ${hx(e,t)};

      & > p {
        text-align: ${hx(e,t)} !important;
      }

      & .rich-text--image {
        text-align: ${hx(e,t)} !important;
      }

      ${fx(hx(e,t))};
    `};
